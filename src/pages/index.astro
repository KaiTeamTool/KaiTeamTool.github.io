---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { SITE } from '../config';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);

// Lifecycle stages in canonical order; archive renders last and muted.
const CATS = [
  { id: 'idea', label: 'idea' },
  { id: 'in-progress', label: 'in-progress' },
  { id: 'active', label: 'active' },
  { id: 'archive', label: 'archive' },
] as const;

const groups = CATS.map((cat) => ({
  ...cat,
  items: projects.filter((p) => p.data.status === cat.id),
})).filter((g) => g.items.length > 0);
---

<Base title={`${SITE.name} — indie portfolio`}>
  <section class="wrap hero">
    <div class="terminal">
      <!-- window chrome -->
      <div class="term-bar">
        <span class="tdot"></span><span class="tdot"></span><span class="tdot"></span>
        <span class="term-path">{SITE.termPath}</span>
      </div>

      <div class="term-body">
        <div class="cmd">
          <span class="run">$ ls ./projects</span><span class="cursor"></span>
        </div>

        <h1 class="title">{SITE.name}</h1>

        {projects.length === 0 ? (
          <>
            <p class="subtitle">// nothing shipped here yet — building in the open</p>
            <div class="empty">
              <span class="empty-line">$ ls ./projects</span>
              <span class="empty-line dim">// no projects yet — check back soon</span>
            </div>
          </>
        ) : (
          <>
            <p class="subtitle">// {projects.length} things I'm building, mostly at night</p>

            <div id="projects" class="filters" role="tablist">
              <button class="filter is-active" data-filter="all">all · {projects.length}</button>
              {groups.map((g) => (
                <button class="filter" data-filter={g.id}>
                  <span class={`dot ${g.id}`}></span>{g.label} · {g.items.length}
                </button>
              ))}
            </div>

            <div class="cat-groups">
              {groups.map((g) => (
                <section class={`cat-group ${g.id === 'archive' ? 'is-muted' : ''}`} data-cat={g.id}>
                  <h2 class="cat-head">
                    <span class={`dot ${g.id}`}></span>{g.label}
                    <span class="cat-count">{g.items.length}</span>
                  </h2>
                  <div class="grid">
                    {g.items.map((p) => (
                      <ProjectCard
                        slug={p.id}
                        title={p.data.title}
                        tagline={p.data.tagline}
                        status={p.data.status}
                        stack={p.data.stack}
                      />
                    ))}
                  </div>
                </section>
              ))}
            </div>
          </>
        )}
      </div>
    </div>

    <!-- about -->
    <section id="about" class="about">
      <div class="about-prompt">$ whoami</div>
      <p class="about-body">
        I'm a solo developer who builds small, sharp tools — mostly terminal
        apps, native bits, and the occasional weekend web thing. Everything here
        is something I actually use. Some are <span class="hl-live">live</span>,
        some are still <span class="hl-wip">cooking</span>. I build in public, so
        the source is usually a click away.
      </p>
      <div class="about-links">
        <a href={SITE.github}>github ↗</a>
        <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
      </div>
    </section>
  </section>
</Base>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>('.filter');
  const sections = document.querySelectorAll<HTMLElement>('.cat-group');
  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.filter;
      filters.forEach((b) => b.classList.toggle('is-active', b === btn));
      sections.forEach((s) => {
        s.hidden = target !== 'all' && s.dataset.cat !== target;
      });
    });
  });
</script>

<style>
  .hero { padding-top: 44px; }

  /* terminal window ------------------------------------------- */
  .terminal {
    background: var(--panel);
    border: 1px solid var(--line-2);
    border-radius: var(--radius);
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.45);
    overflow: hidden;
  }
  .term-bar {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--line);
  }
  .tdot { width: 10px; height: 10px; border-radius: 50%; background: #3a3d42; }
  .term-path {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--faint);
    margin-left: 8px;
  }
  .term-body { padding: 34px clamp(20px, 4vw, 40px) 40px; }

  .cmd { font-family: var(--mono); font-size: 13px; margin-bottom: 22px; }
  .cmd .run { color: var(--green); }

  .title {
    font-family: var(--display);
    font-weight: 700;
    font-size: clamp(34px, 6vw, 52px);
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: var(--fg);
    margin: 0;
  }
  .subtitle {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted-2);
    margin: 10px 0 0;
  }

  /* filter tabs ----------------------------------------------- */
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 26px 0 24px;
  }
  .filter {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted-2);
    background: transparent;
    border: 1px solid var(--line-2);
    border-radius: 2px;
    padding: 5px 10px;
    cursor: pointer;
    transition: border-color 0.16s ease, color 0.16s ease, background 0.16s ease;
  }
  .filter:hover { color: var(--fg-soft); border-color: var(--line-3); }
  .filter.is-active {
    color: var(--fg);
    border-color: #3a3f47;
    background: var(--panel-2);
  }

  /* empty state ----------------------------------------------- */
  .empty {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 26px;
    padding: 22px;
    border: 1px dashed var(--dash);
    border-radius: var(--radius);
    font-family: var(--mono);
    font-size: 12px;
  }
  .empty-line { color: var(--green); }
  .empty-line.dim { color: var(--faint); }

  /* grouped sections ------------------------------------------ */
  .cat-groups { display: flex; flex-direction: column; gap: 30px; }
  .cat-group[hidden] { display: none; }
  .cat-group.is-muted { opacity: 0.62; }
  .cat-head {
    display: flex;
    align-items: center;
    gap: 9px;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.5px;
    color: var(--muted-2);
    margin: 0 0 12px;
  }
  .cat-count {
    color: var(--faint);
    border: 1px solid var(--line-2);
    border-radius: 2px;
    padding: 1px 6px;
    font-size: 10px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 12px;
  }

  /* about ----------------------------------------------------- */
  .about {
    margin-top: 56px;
    border: 1px solid var(--line-2);
    border-radius: var(--radius);
    background: var(--panel);
    padding: 30px clamp(20px, 4vw, 40px) 32px;
  }
  .about-prompt {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--green);
    margin-bottom: 16px;
  }
  .about-body {
    font-family: var(--display);
    font-size: clamp(15px, 2.2vw, 18px);
    line-height: 1.75;
    color: var(--fg-soft);
    max-width: 60ch;
    margin: 0;
  }
  .hl-live { color: var(--green); }
  .hl-wip { color: var(--amber); }
  .about-links {
    display: flex;
    gap: 22px;
    margin-top: 22px;
    font-family: var(--mono);
    font-size: 12px;
  }
  .about-links a {
    color: var(--muted-2);
    border-bottom: 1px dotted var(--line-3);
    padding-bottom: 2px;
  }
  .about-links a:hover { color: var(--green); border-color: var(--green); }

  @media (max-width: 480px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
