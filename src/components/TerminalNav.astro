---
// N1 — terminal prompt bar (from the wireframe nav explorations)
import { SITE } from '../config';
const { pathname } = Astro.url;
const onHome = pathname === '/' || pathname === '';
---

<header class="nav">
  <div class="wrap nav-inner">
    <a class="prompt" href="/" aria-label={`${SITE.name} home`}>
      <span class="user">{SITE.promptUser}</span><span class="path">:~$</span>
    </a>
    <nav class="links" aria-label="Primary">
      <a href={onHome ? '#projects' : '/#projects'}>projects</a>
      <a href={onHome ? '#about' : '/#about'}>about</a>
      <a href={`mailto:${SITE.email}`}>contact</a>
    </nav>
    <span class="cursor" aria-hidden="true"></span>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(10, 11, 12, 0.82);
    backdrop-filter: saturate(140%) blur(8px);
    -webkit-backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid var(--line);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    gap: 16px;
    height: 52px;
  }
  .prompt {
    font-family: var(--mono);
    font-size: 13px;
    letter-spacing: 0.2px;
    white-space: nowrap;
  }
  .prompt .user { color: var(--green); }
  .prompt .path { color: var(--muted-2); }

  .links {
    display: flex;
    gap: 18px;
    font-family: var(--mono);
    font-size: 13px;
  }
  .links a {
    color: #9a9da3;
    padding: 2px 0;
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .links a:hover,
  .links a:focus-visible {
    color: var(--fg);
    border-color: var(--green);
    outline: none;
  }

  .nav .cursor { margin-left: auto; height: 15px; }

  @media (max-width: 460px) {
    .links { gap: 12px; font-size: 12px; }
    .prompt .user { font-size: 12px; }
    .nav .cursor { display: none; }
  }
</style>
