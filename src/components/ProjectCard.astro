---
type Status = 'idea' | 'in-progress' | 'active' | 'archive';
interface Props {
  slug: string;
  title: string;
  tagline: string;
  status: Status;
  stack: string[];
}
const STATUS_LABELS: Record<Status, string> = {
  idea: 'Idea',
  'in-progress': 'In progress',
  active: 'Active',
  archive: 'Archived',
};
const { slug, title, tagline, status, stack } = Astro.props;
---

<a class="card" href={`/projects/${slug}`}>
  <div class="card-top">
    <span class="card-title">{title}</span>
    <span class={`dot ${status}`} title={STATUS_LABELS[status]}></span>
  </div>
  <p class="card-desc">{tagline}</p>
  <div class="card-tags">
    {stack.slice(0, 3).map((t) => <span class="tag">{t}</span>)}
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--line-2);
    border-radius: var(--radius);
    padding: 16px 16px 15px;
    background: var(--panel);
    transition: border-color 0.16s ease, transform 0.16s ease, background 0.16s ease;
  }
  .card:hover,
  .card:focus-visible {
    border-color: #3a3f47;
    background: var(--panel-2);
    transform: translateY(-2px);
    outline: none;
  }
  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }
  .card-title {
    font-family: var(--display);
    font-weight: 700;
    font-size: 15px;
    color: var(--fg);
  }
  .card:hover .card-title { color: var(--green); }
  .card-desc {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    line-height: 1.55;
    margin: 8px 0 12px;
  }
  .card-tags {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
    margin-top: auto;
  }
</style>
